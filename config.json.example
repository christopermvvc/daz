{
  "core": {
    "rooms": [
      {
        "id": "main",
        "channel": "your_channel_name",
        "username": "your_bot_username",
        "password": "your_bot_password",
        "enabled": true,
        "reconnect_attempts": 10,
        "cooldown_minutes": 30
      }
    ],
    "database": {
      "host": "localhost",
      "port": 5432,
      "database": "daz",
      "user": "your_db_user",
      "password": "your_db_password"
    }
  },
  "event_bus": {
    "buffer_sizes": {
      "cytube.event": 2000,
      "sql.request": 500,
      "plugin.request": 2000
    }
  },
  "plugins": {
    "sql": {
      "database": {
        "host": "localhost",
        "port": 5432,
        "database": "daz",
        "user": "your_db_user",
        "password": "your_db_password",
        "max_connections": 20,
        "max_conn_lifetime": 3600,
        "connect_timeout": 30
      },
      "logger_rules": [
        {
          "event_pattern": "cytube.event.*",
          "enabled": true,
          "table": "daz_core_events"
        }
      ]
    },
    "eventfilter": {
      "command_prefix": "!"
    },
    "ollama": {
      "enabled": true,
      "follow_up_enabled": true,
      "follow_up_window_seconds": 180,
      "follow_up_respond_all_messages": false,
      "follow_up_max_messages": 4,
      "follow_up_min_interval_ms": 2500,
      "keep_alive": "5m"
    },
    "greeter": {
      "use_greeting_engine": true,
      "enforce_question_greeting": true,
      "enable_follow_up_mode": true,
      "fortune_probability": 0.20
    },
    "economy": {},
    "pissingcontest": {
      "bot_username": "",
      "challenge_duration_seconds": 30,
      "cooldown_minutes": 5
    },
    "playerstate": {},
    "bufftracker": {
      "buff_dictionary_path": "internal/plugins/bufftracker/dictionaries/buffs.json",
      "debuff_dictionary_path": "internal/plugins/bufftracker/dictionaries/debuffs.json"
    },
    "update": {
      "repo_path": "",
      "branch": "master",
      "remote": "origin",
      "build_command": ["make", "build"],
      "restart_command": ["systemctl", "restart", "daz"],
      "operation_timeout_seconds": 300
    },
    "fishing": {}
  }
}
