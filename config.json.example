{
  "core": {
    "rooms": [
      {
        "id": "main",
        "channel": "your_channel_name",
        "username": "your_bot_username",
        "password": "your_bot_password",
        "enabled": true,
        "reconnect_attempts": 10,
        "cooldown_minutes": 30
      }
    ],
    "database": {
      "host": "localhost",
      "port": 5432,
      "database": "daz",
      "user": "your_db_user",
      "password": "your_db_password"
    }
  },
  "event_bus": {
    "buffer_sizes": {
      "cytube.event": 2000,
      "sql.request": 500,
      "plugin.request": 2000
    }
  },
  "plugins": {
    "sql": {
      "database": {
        "host": "localhost",
        "port": 5432,
        "database": "daz",
        "user": "your_db_user",
        "password": "your_db_password",
        "max_connections": 20,
        "max_conn_lifetime": 3600,
        "connect_timeout": 30
      },
      "background_max_connections": 5,
      "background_queue_max": 40,
      "background_queue_wait_ms": 1200,
      "core_event_queue_size": 4000,
      "core_event_batch_size": 64,
      "core_event_flush_ms": 200,
      "logger_rules": [
        {
          "event_pattern": "cytube.event.*",
          "enabled": true,
          "table": "daz_core_events"
        }
      ]
    },
    "eventfilter": {
      "command_prefix": "!"
    },
    "wsbridge": {
      "enabled": false,
      "listen_addr": ":8091",
      "path": "/ws",
      "default_channel": "your_channel_name",
      "session_cookie_name": "daz_session",
      "allowed_origins": [
        "https://your-ui.example.com"
      ],
      "auth_timeout_seconds": 10,
      "heartbeat_interval_seconds": 20,
      "client_timeout_seconds": 60,
      "max_message_bytes": 16384,
      "max_subscriptions": 64,
      "max_outbound_queue": 256,
      "rate_limit_per_second": 20,
      "rate_limit_burst": 40,
      "tokens": [
        {
          "token": "replace-with-strong-random-token",
          "username": "ui_user",
          "rank": 3,
          "admin": false,
          "channels": ["your_channel_name"]
        }
      ]
    },
    "help": {
      "show_aliases": true,
      "generate_html": true,
      "include_restricted": true,
      "publish_min_interval_seconds": 60
    },
    "gallery": {
      "generate_html": true,
      "publish_min_interval_seconds": 60,
      "publish_retry_max": 3,
      "publish_retry_backoff_ms": 1500
    },
    "mediatracker": {
      "stats_update_interval_minutes": 5,
      "playlist_ingest_batch_size": 20,
      "playlist_ingest_pause_ms": 150,
      "playlist_phase2_delay_ms": 750,
      "startup_ingest_window_seconds": 120,
      "startup_ingest_batch_size": 10,
      "startup_ingest_pause_ms": 300,
      "startup_phase2_delay_ms": 2000
    },
    "usertracker": {
      "inactivity_timeout_minutes": 30,
      "userlist_join_delay_ms": 15,
      "userlist_join_queue_max": 2000,
      "userlist_debounce_ms": 3000
    },
    "ollama": {
      "enabled": true,
      "follow_up_enabled": true,
      "follow_up_window_seconds": 180,
      "follow_up_respond_all_messages": false,
      "follow_up_max_messages": 4,
      "follow_up_min_interval_ms": 2500,
      "keep_alive": "5m"
    },
    "speechflavor": {
      "enabled": true,
      "preserve_tokens": true,
      "max_tokens": 96,
      "temperature": 0.6,
      "timeout_ms": 5000
    },
    "greeter": {
      "use_greeting_engine": true,
      "enforce_question_greeting": true,
      "enable_follow_up_mode": true,
      "fortune_probability": 0.20
    },
    "economy": {},
    "pissingcontest": {
      "bot_username": "",
      "challenge_duration_seconds": 30,
      "cooldown_minutes": 5
    },
    "playerstate": {},
    "bufftracker": {
      "buff_dictionary_path": "internal/plugins/bufftracker/dictionaries/buffs.json",
      "debuff_dictionary_path": "internal/plugins/bufftracker/dictionaries/debuffs.json"
    },
    "update": {
      "repo_path": "",
      "branch": "master",
      "remote": "origin",
      "build_command": ["make", "build"],
      "restart_command": ["systemctl", "restart", "daz"],
      "operation_timeout_seconds": 300
    },
    "fishing": {}
  }
}
